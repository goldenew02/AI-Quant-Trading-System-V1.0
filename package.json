{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "reset-admin-totp": "tsx scripts/reset-admin-totp.ts",
    "auth-doctor": "tsx scripts/auth-doctor.ts",
    "auth-regression": "tsx scripts/auth-regression.ts",
    "auth-http-regression": "tsx scripts/auth-http-regression.ts",
    "auth-kv-regression": "tsx scripts/auth-kv-regression.ts",
    "strict-audit-regression": "tsx scripts/strict-audit-regression.ts",
    "sql-restore-regression": "tsx scripts/sql-restore-regression.ts",
    "order-state-regression": "tsx scripts/order-state-regression.ts",
    "broker-adapter-regression": "tsx scripts/broker-adapter-regression.ts",
    "test:safety": "npm run order-state-regression && npm run broker-adapter-regression && npm run sql-restore-regression",
    "test:auth": "npm run auth-regression && npm run auth-http-regression && npm run auth-kv-regression && npm run strict-audit-regression && npm run test:safety",
    "sync-admin-password": "tsx scripts/sync-admin-password.ts",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.18.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "sqlite3": "^6.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/sqlite3": "^3.1.11",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
