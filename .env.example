# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Boot-level administrator configuration
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=Aegis_c391e4dfc009!
BOOTSTRAP_ADMIN_TOTP_SECRET=Y2V2V4FYU5XL5U2R

# Safety switches for synchronizing credentials from environment on boot
# ADMIN_PASSWORD_SYNC_ON_BOOT: If true, overwrites database admin password on boot if it differs from .env (defaults to true)
ADMIN_PASSWORD_SYNC_ON_BOOT=true
# ADMIN_TOTP_SYNC_ON_BOOT: If true, overwrites database admin TOTP secret on boot (defaults to false for safety)
ADMIN_TOTP_SYNC_ON_BOOT=false

# Session and encryption configurations
ENCRYPTION_KEY=jH9QOrwCFaEGVtNrWQFIPHDOz0PML/R6YAk/63QjlC4=
SESSION_SECRET=pxzqDZBa/K6WOaXZQUbqi1sIE15WaJ+3Jthm4tIAnTs=

# TOTP Verification parameters
# TOTP_WINDOW_STEPS: Standard check window for clock drift (default 1 step = +/- 30s. Max safe limit is 2)
TOTP_WINDOW_STEPS=1

# Interactive Brokers Gateway configuration
IB_GATEWAY_URL=https://127.0.0.1:5000/v1/api
IB_ACCOUNT_ID=DUxxxxxxxx


# ==============================================================================
# ENVIRONMENT DEPLOYMENT TEMPLATES
# ==============================================================================

# ------------------------------------------------------------------------------
# TEMPLATE 1: LOCAL HTTP DEVELOPMENT & TESTING
# ------------------------------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000
COOKIE_SAMESITE=none
COOKIE_SECURE=true

# ------------------------------------------------------------------------------
# TEMPLATE 2: PRODUCTION HTTPS (SAME DOMAIN / NO IFRAME)
# ------------------------------------------------------------------------------
# NODE_ENV=production
# APP_URL=https://your-domain.example.com
# COOKIE_SAMESITE=lax
# COOKIE_SECURE=true

# ------------------------------------------------------------------------------
# TEMPLATE 3: AI STUDIO LIVE PREVIEW / CROSS-DOMAIN IFRAME (HTTPS REQUIRED)
# ------------------------------------------------------------------------------
# NODE_ENV=production
# APP_URL=https://your-preview-app.run.app
# COOKIE_SAMESITE=none
# COOKIE_SECURE=true
