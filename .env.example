# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="replace-with-your-gemini-api-key"

# Boot-level administrator configuration
BOOTSTRAP_ADMIN_USER=replace-with-admin-username
BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-random-password
# BOOTSTRAP_ADMIN_TOTP_SECRET should normally be empty; enroll dynamically after login.
BOOTSTRAP_ADMIN_TOTP_SECRET=

# Safety switches for synchronizing credentials from environment on boot
# ADMIN_PASSWORD_SYNC_ON_BOOT: If true, overwrites database admin password on boot if it differs from .env (defaults to true)
ADMIN_PASSWORD_SYNC_ON_BOOT=true
# ADMIN_TOTP_SYNC_ON_BOOT: If true, overwrites database admin TOTP secret on boot (defaults to false for safety)
ADMIN_TOTP_SYNC_ON_BOOT=false

# Session and encryption configurations
ENCRYPTION_KEY=replace-with-32-byte-base64-random
SESSION_SECRET=replace-with-64-byte-base64-random

# Safety gate for live trading/broker orders
# LIVE_TRADING_ENABLED: If false, starting any bot in 'live' execution mode is strictly blocked on backend
LIVE_TRADING_ENABLED=false

# TOTP Verification parameters
# TOTP_WINDOW_STEPS: Standard check window for clock drift (default 1 step = +/- 30s. Max safe limit is 2)
TOTP_WINDOW_STEPS=1

# Interactive Brokers Gateway configuration
IB_GATEWAY_URL=https://127.0.0.1:5000/v1/api
IB_ACCOUNT_ID=DUxxxxxxxx


# ==============================================================================
# ENVIRONMENT DEPLOYMENT TEMPLATES
# ==============================================================================

# ------------------------------------------------------------------------------
# TEMPLATE 1: LOCAL HTTP DEVELOPMENT & TESTING
# ------------------------------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# ------------------------------------------------------------------------------
# TEMPLATE 2: PRODUCTION HTTPS (SAME DOMAIN / NO IFRAME)
# ------------------------------------------------------------------------------
# NODE_ENV=production
# APP_URL=https://your-domain.example.com
# COOKIE_SAMESITE=lax
# COOKIE_SECURE=true

# ------------------------------------------------------------------------------
# TEMPLATE 3: AI STUDIO LIVE PREVIEW / CROSS-DOMAIN IFRAME (HTTPS REQUIRED)
# ------------------------------------------------------------------------------
# NODE_ENV=production
# APP_URL=https://your-preview-app.run.app
# COOKIE_SAMESITE=none
# COOKIE_SECURE=true
# FRAME_ANCESTORS='self',https://ai.studio,https://*.google.com
